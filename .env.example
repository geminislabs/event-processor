# Kafka connection settings (used by producer example)
KAFKA_BROKERS=localhost:9092
# consumer siscom-minimal credentials
KAFKA_TOPIC=telemetry.raw
KAFKA_GROUP_ID=event-processor
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_USERNAME=admin
KAFKA_PASSWORD=admin-secret
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_ENABLE_AUTO_COMMIT=false
KAFKA_AUTO_OFFSET_RESET=latest

# Producer-specific (if producer uses different user/topic)
# If set, these override the default `KAFKA_*` values for the producer only.
KAFKA_PRODUCER_TOPIC=unit-events
KAFKA_PRODUCER_USERNAME=producer_user
KAFKA_PRODUCER_PASSWORD=producer_password

DB_HOST=localhost
DB_PORT=5432
DB_NAME=event_processor
DB_USER=postgres
DB_PASSWORD=postgres
DB_MAX_CONNECTIONS=10

# App settings
LOG_LEVEL=info
HEALTH_BIND_ADDR=0.0.0.0:8080
BATCH_SIZE=500
BATCH_TIMEOUT_MS=1000
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=10000
